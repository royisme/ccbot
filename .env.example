# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Multi-instance: Telegram group chat ID this instance owns (optional)
# When set, this instance only processes updates from this group.                                                                                                                        
# Get the ID via @userinfobot or @RawDataBot in your group.                                                                                                                            
# CCBOT_GROUP_ID=-1001234567890                                                         
                                                                     
# Multi-instance: display name for this instance (optional, defaults to hostname)
# CCBOT_INSTANCE_NAME=bot-1

# Per-provider launch command overrides (optional)
# CCBOT_CLAUDE_COMMAND=my-claude-wrapper (defaults to "claude")
# CCBOT_CODEX_COMMAND=my-codex-wrapper (defaults to "codex")
# CCBOT_GEMINI_COMMAND=my-gemini-wrapper (defaults to "gemini")
#
# Claude config directory (optional, defaults to ~/.claude)
# For Claude wrappers (ce, cc-mirror, zai) that use a different config location.
# Affects hook install, command discovery, and session monitoring.
# CLAUDE_CONFIG_DIR=~/.claude-custom

# Show hidden (dot) directories in the directory browser (optional, defaults to false)
# CCBOT_SHOW_HIDDEN_DIRS=false

# ── Voice message transcription (Whisper API) ────────────────────────────────
# Enable by setting CCBOT_WHISPER_PROVIDER to "openai" or "groq".
# Leave empty (default) to disable — voice messages will show an unsupported hint.
#
# Option A: Groq (recommended — fast, generous free tier)
# CCBOT_WHISPER_PROVIDER=groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#
# Option B: OpenAI
# CCBOT_WHISPER_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
#
# Option C: Any OpenAI-compatible endpoint (e.g. local Whisper server)
# CCBOT_WHISPER_PROVIDER=openai
# CCBOT_WHISPER_API_KEY=your_key
# CCBOT_WHISPER_BASE_URL=http://localhost:8000/v1
# CCBOT_WHISPER_MODEL=whisper-1
#
# Optional tweaks (apply to all providers):
# CCBOT_WHISPER_MODEL=whisper-large-v3-turbo   # override default model
# CCBOT_WHISPER_LANGUAGE=en                    # force language (omit = auto-detect)
